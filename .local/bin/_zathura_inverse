#!/bin/sh

# Jump from zathura SyncTeX source positions into Neovim.

server_arg=""
case "$1" in
--server=*)
    server_arg="${1#--server=}"
    shift
    ;;
--server)
    shift
    server_arg="${1:-}"
    [ "$#" -gt 0 ] && shift
    ;;
esac

line="${1:-1}"
[ "$#" -gt 0 ] && shift
column=1

is_int() {
    case "$1" in
    "" | -) return 1 ;;
    -*) value="${1#-}" ;;
    *) value="$1" ;;
    esac
    case "${value}" in
    *[!0-9]* | "") return 1 ;;
    *) return 0 ;;
    esac
}

# zathura may pass either: line file, or line column file. Column can be -1.
if is_int "${1}"; then
    column="${1}"
    shift
elif [ "${1}" = "%{column}" ]; then
    shift
fi

file="$*"
is_int "${line}" || line=1
is_int "${column}" || column=1
[ "${line}" -lt 1 ] && line=1
[ "${column}" -lt 1 ] && column=1

nvim_expr() {
    command nvim --server "$1" --remote-expr "$2" 2>/dev/null
}

is_server() {
    [ -n "$1" ] && nvim_expr "$1" "1" >/dev/null
}

add_candidate() {
    [ -S "$1" ] || return
    case " ${candidates} " in
    *" $1 "*) ;;
    *) candidates="${candidates} $1" ;;
    esac
}

resolve_file() {
    case "$1" in
    /*)
        [ -e "$1" ] && realpath "$1" || printf "%s\n" "$1"
        return
        ;;
    esac

    if [ -e "$1" ]; then
        realpath "$1"
        return
    fi

    for server in ${candidates}; do
        cwd=$(nvim_expr "${server}" "getcwd()")
        [ -e "${cwd}/$1" ] && realpath "${cwd}/$1" && return
    done

    printf "%s\n" "$1"
}

select_server() {
    for server in "${server_arg}" "${NVIM_SERVER}" "${NVIM}" "${NVIM_PIPE}"; do
        is_server "${server}" && printf "%s\n" "${server}" && return
    done

    first=""
    for server in ${candidates}; do
        is_server "${server}" || continue
        [ -z "${first}" ] && first="${server}"

        cwd=$(nvim_expr "${server}" "getcwd()")
        case "${file}" in
        "${cwd}" | "${cwd}"/*)
            printf "%s\n" "${server}"
            return
            ;;
        esac
    done

    [ -n "${first}" ] && printf "%s\n" "${first}"
}

candidates=""
add_candidate "${server_arg}"
add_candidate "${NVIM_SERVER}"
add_candidate "${NVIM}"
add_candidate "${NVIM_PIPE}"

runtime_dir="${XDG_RUNTIME_DIR:-/tmp/user/${USER}}"
for server in "${runtime_dir}/nvim"/shell-*.pipe "${runtime_dir}"/nvim.*.0 "/tmp"/nvim*/0; do
    add_candidate "${server}"
done

file=$(resolve_file "${file}")
server=$(select_server)

[ -n "${file}" ] || exit 1
[ -n "${server}" ] || exit 1

file_escaped=$(printf "%s" "${file}" | sed "s/'/''/g")
nvim_expr "${server}" "execute('silent! wall | edit +' . ${line} . ' ' . fnameescape('${file_escaped}') . ' | call cursor(${line}, ${column}) | normal! zz')" >/dev/null || exit 1
