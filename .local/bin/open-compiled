#!/bin/sh

# back-end script that opens a compiled file

file="${1}"

case "${file}" in
/*) ;;
*) file="$(pwd)/${file}" ;;
esac

ext="${file##*.}"
dir=$(dirname "$file")
base="${file%.*}"
synctex_editor="_zathura_inverse %{line} %{column} %{input}"

if [ -n "${NVIM_SERVER}" ]; then
    synctex_editor="_zathura_inverse --server=${NVIM_SERVER} %{line} %{column} %{input}"
fi

if command -v launchctl >/dev/null 2>&1; then
    dbus_socket=$(launchctl getenv DBUS_LAUNCHD_SESSION_BUS_SOCKET 2>/dev/null)
    if [ -z "${dbus_socket}" ]; then
        dbus_socket=$(launchctl asuser "$(id -u)" launchctl getenv DBUS_LAUNCHD_SESSION_BUS_SOCKET 2>/dev/null)
    fi
    if [ -n "${dbus_socket}" ]; then
        export DBUS_LAUNCHD_SESSION_BUS_SOCKET="${dbus_socket}"
        export DBUS_SESSION_BUS_ADDRESS="unix:path=${dbus_socket}"
    fi
fi

zathura_open() {
    setsid -f zathura "$@" >/dev/null 2>&1
}

find_pdf() {
    wanted="${base}.pdf"
    if [ -f "${wanted}" ]; then
        printf "%s\n" "${wanted}"
        return 0
    fi

    search_dir="${dir}"
    while :; do
        if [ -f "${search_dir}/main.pdf" ]; then
            printf "%s\n" "${search_dir}/main.pdf"
            return 0
        fi

        set -- "${search_dir}"/*.pdf
        if [ -e "$1" ]; then
            printf "%s\n" "$1"
            return 0
        fi

        [ "${search_dir}" = "/" ] && break
        parent_dir=$(dirname "${search_dir}")
        [ "${parent_dir}" = "${search_dir}" ] && break
        search_dir="${parent_dir}"
    done

    return 1
}

ensure_synctex() {
    synctex="${pdf%.pdf}.synctex.gz"
    [ -s "${synctex}" ] && [ ! "${synctex}" -ot "${pdf}" ] && return
    command -v compile >/dev/null 2>&1 || return
    compile "${file}" >/dev/null 2>&1 || return
    pdf=$(find_pdf) || exit 1
}

case "${ext}" in
md)
    zathura_open "${base}.pdf"
    ;;
tex)
    line="${2}"
    column="${3:-1}"
    pdf=$(find_pdf) || exit 1
    ensure_synctex

    if [ -n "${line}" ]; then
        zathura_open -x "${synctex_editor}" "--synctex-forward=${line}:${column}:${file}" "${pdf}" || zathura_open "${pdf}"
    else
        zathura_open -x "${synctex_editor}" "${pdf}" || zathura_open "${pdf}"
    fi
    ;;
esac
