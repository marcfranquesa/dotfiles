[user]
    email = git@marcfranquesa.com 
    name = Marc Franquesa Monés
    signingKey = ~/.ssh/git.pub
[alias]
    co = checkout
    cp = cherry-pick
[init]
    defaultBranch = main
[diff]
    tool = vimdiff
[include]
    path = ~/.config/git/local
[gpg]
    format = ssh
[commit]
    gpgsign = true
[tag]
    gpgsign = true
[gpg "ssh"]
    allowedSignersFile = ~/.config/git/allowed-signers
